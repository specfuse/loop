#!/usr/bin/env bash
#
# Copyright 2026 Specfuse contributors
# Licensed under the Apache License, Version 2.0. See LICENSE.
#
# pre-commit — block commits that introduce leaks (FEAT-2026-0020/T16).
#
# Read-only, fast, sandbox-safe: it only runs the leak_scan detector over the
# STAGED diff (no network, no writes, no history rewrite). See memory
# [prepush_hook_sandbox_corruption] — hooks must never do heavy/destructive work.
#
# INSTALL (once per clone):
#     git config core.hooksPath .specfuse/hooks
#
# EMERGENCY BYPASS:
#     git commit --no-verify
# CI still enforces the same check via the `leak-scan` gate in
# .specfuse/verification.yml, so a bypassed leak is caught before merge.

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
scanner="$repo_root/.specfuse/scripts/leak_scan.py"

if [ ! -f "$scanner" ]; then
  echo "pre-commit: leak_scan.py not found at $scanner" >&2
  exit 1
fi

if ! python3 "$scanner" --staged; then
  echo "pre-commit: leak-scan found issues in the staged changes." >&2
  echo "Fix them, or bypass with: git commit --no-verify  (CI still enforces leak-scan)." >&2
  exit 1
fi
